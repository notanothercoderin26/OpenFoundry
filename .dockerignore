# Keep the build context tight. Multi-stage Dockerfiles only need Go
# source, proto, sql, configs, and frontend source. Everything else stays
# out so we don't ship docs/tests/caches into the daemon.

# === VCS / IDE / OS metadata =================================================
.git
.github
.gitignore
.gitattributes
.editorconfig
.vscode
.idea
.zed
.fleet
.history
.claude
**/.DS_Store
**/Thumbs.db

# === Build artefacts =========================================================
bin/
**/dist
**/build
**/coverage
**/__snapshots__
**/coverage.out
**/*.test
**/*.prof
*.tsbuildinfo
go.work
go.work.sum
/vendor

# === Node / pnpm / Vite ======================================================
**/node_modules
.pnpm-store
apps/web/.vite
apps/web/playwright-report
apps/web/test-results
docs/node_modules
docs/.vitepress/dist
docs/.vitepress/cache
docs/.vitepress/.temp

# === Python ==================================================================
**/__pycache__
**/*.py[cod]
**/*.egg-info
**/.venv
**/venv
**/.tox
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache

# === SDKs (per-package extras not caught above) ==============================
sdks/java/.gradle

# === Documentation / planning material (not needed at build time) ===========
docs/
docs_original_palantir_foundry
Good-practices-architecture
benchmarks
smoke
images
PoC
ARCHITECTURE.md
CHANGELOG.md
CLAUDE.md
CONTRIBUTING.md
README.md
ROADMAP.md
SECURITY.md
TASKS_*.md

# === Secrets / runtime overlays (never copied into images) ==================
**/.env
**/.env.*
!**/.env.example
.openfoundry
.direnv

# === Terraform local state ==================================================
**/.terraform
**/*.tfstate
**/*.tfstate.*
**/*.tfplan

# === Logs / caches ===========================================================
**/*.log
**/.cache
**/.turbo

# === Always include this file itself ========================================
!.dockerignore
