# Ignore only local and generated artifacts.
# Keep source, docs, lockfiles, static assets, and versioned generated specs.

# === OS / editors ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
.zed/
.fleet/
.history/
*.swp
*.swo

# === Local environment / secrets ============================================
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
!.env.*.sample
!.env.template
!.env.*.template
.direnv/

# === Go ======================================================================
# `make tools` installs buf / golangci-lint / sqlc / gofumpt here; `make
# build-services` writes one binary per service into ./bin/.
/bin/
# Go workspace files used for local multi-module dev / worktree runs.
go.work
go.work.sum
# Go test outputs.
coverage.out
coverage.html
*.coverprofile
*.test
*.prof
# Optional vendor directory; not used today but standard to ignore.
/vendor/

# === Node / pnpm / Vite =====================================================
# pnpm-only workspace — npm/yarn artefacts intentionally not listed.
node_modules/
.pnpm-store/
.vite/
apps/web/dist/
coverage/
playwright-report/
test-results/
*.tsbuildinfo
.eslintcache
pnpm-debug.log*

# === Python (tools, runtime, SDK) ===========================================
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.tox/
.mypy_cache/
.pytest_cache/
.ruff_cache/
pip-wheel-metadata/

# === SDK build outputs ======================================================
sdks/python/**/dist/
sdks/python/**/build/
sdks/java/**/build/
sdks/java/**/.gradle/
sdks/typescript/**/dist/

# === Terraform local state ==================================================
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# === Local runtime output ===================================================
.openfoundry/
tmp/
temp/
.cache/
*.log
*.pid
*.seed
*.tmp
*.temp

# === Locally-built Go binaries — services ===================================
# `cd services/<x> && go build ./cmd/<x>` writes the binary to
# services/<x>/<x>. Use a negation pattern so we don't have to enumerate
# all 50 services. Only known source/config file types under
# services/<x>/ are kept tracked.
/services/*/*
!/services/*/*/
!/services/*/*.md
!/services/*/*.yaml
!/services/*/*.yml
!/services/*/*.json
!/services/*/*.sbt
!/services/*/Dockerfile
!/services/*/.dockerignore
!/services/*/.gitignore

# === Locally-built Go binaries — tools ======================================
# Same idea for `cd tools/<x> && go build .` writing tools/<x>/<x>.
/tools/*/*
!/tools/*/*/
!/tools/*/*.go
!/tools/*/*.md
!/tools/*/*.sh
!/tools/*/*.py
!/tools/*/*.json
!/tools/*/*.yaml
!/tools/*/*.yml
!/tools/*/Dockerfile
!/tools/*/.gitignore

# === Locally-built binaries at repo root ====================================
# `go build ./tools/<x>` or `go build ./services/<x>/cmd/<x>` from the repo
# root writes the binary as ./<x>. Keep this list in sync with the tools
# that ship a main.go and with services that devs build from the root.
/route-audit
/sql-lint
/bus-allowlist
/data-residency
/capabilities-snapshot
/of-cli
/of-sdk-gen
/identity-federation-service

# === Intentionally kept in Git ==============================================
# - apps/web/public/generated/openapi/openfoundry.json
# - apps/web/public/generated/terraform/openfoundry-provider.json
# - infra/terraform/providers/openfoundry/provider.schema.json

# === Misc local-only =========================================================
# Local imported docs snapshot (kept out of git).
docs_original_palantir_foundry/
# ArgoCD: real Slack creds (only the .example.yaml is checked in).
infra/argocd/notifications/slack-secret.yaml
# Claude Code local config / worktrees.
.claude/
# PoC sample-data downloads (multi-GB; spec lives in
# PoC/<vertical>/assets/sample-data-manifest.yaml — the payloads
# themselves are operator-fetched per the runbook, not committed).
infra/poc-data/
# Operator-supplied env files for PoC fetch scripts (API keys etc.).
.openfoundry/poc-*.env
